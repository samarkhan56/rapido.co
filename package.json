{
  "name": "rapido-solutions-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --config frontend/vite.config.js",
    "dev:api": "node backend/index.js",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "vite build",
    "preview": "vite preview --config frontend/vite.config.js",
    "start:api": "node backend/index.js"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.0.0",
    "mongoose": "^9.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.0"
  }
}
